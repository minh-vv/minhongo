generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String?
  avatarUrl    String?  // URL ảnh đại diện
  learningGoal String?  // Mục tiêu học tập cá nhân
  isAdmin      Boolean  @default(false)
  isBlocked    Boolean  @default(false)
  onboardedAt  DateTime? // Đã hoàn tất onboarding lộ trình chưa
  createdAt    DateTime @default(now())

  // Forgot-password reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  decks         Deck[]
  cardProgress  CardProgress[]
  courseEnrolls UserCourseProgress[]
  lessonProgress UserLessonProgress[]
  customRoadmaps CustomRoadmap[]
  grammarPractices GrammarPractice[]
  savedExamples    UserSavedExample[]
  feedbacks        Feedback[]
  feedbackComments FeedbackComment[]
}

enum DeckCategory {
  HANTU     // Hán tự (Kanji)
  TUVUNG    // Từ vựng (Vocabulary)
  NGUPHAP   // Ngữ pháp (Grammar)
  TUHOC     // Tự học (User created)
}

model Deck {
  id          String       @id @default(uuid())
  name        String
  description String?
  isPublic    Boolean      @default(false)
  category    DeckCategory @default(TUHOC)
  jlptLevel   Int?         // JLPT level: 5, 4, 3, 2, 1
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cards       Card[]
  lessonDecks LessonDeck[]
  lessonTests LessonTest[]
}

model Card {
  id           String         @id @default(uuid())
  front        String
  back        String
  romaji       String?
  example      String?
  audioUrl     String?
  imageUrl     String?
  jlptLevel    Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  deckId       String
  deck         Deck           @relation(fields: [deckId], references: [id], onDelete: Cascade)
  progress     CardProgress[]
  grammarPractices GrammarPractice[]
  savedExamples    UserSavedExample[]
}

// Log từng lần ôn tập — dùng để vẽ biểu đồ lịch sử học
model ReviewLog {
  id         String   @id @default(uuid())
  userId     String
  cardId     String
  deckId     String
  quality    Int      // 0-3 (SM-2 quality)
  reviewedAt DateTime @default(now())

  @@index([userId, reviewedAt])
}

// Lưu tiến độ học của user với mỗi thẻ (SM-2 algorithm)
model CardProgress {
  id              String   @id @default(uuid())
  userId          String
  cardId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card            Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  // SM-2 parameters
  easeFactor      Float    @default(2.5)    // Hệ số dễ (2.5 là mặc định)
  interval        Int      @default(0)      // Khoảng cách ngày đến lần ôn tiếp
  repetitions     Int      @default(0)      // Số lần lặp thành công
  
  // Review tracking
  nextReviewDate  DateTime @default(now()) // Ngày ôn tập tiếp theo
  lastReviewDate  DateTime?
  
  // Trạng thái đánh dấu sao
  isStarred       Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, cardId]) // Mỗi user chỉ có 1 progress cho mỗi thẻ
}

// Cặp key–value cấu hình hệ thống (admin chỉnh, ứng dụng đọc)
model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ============================================================================
// COURSE / LESSON / ROADMAP
// ============================================================================
// Course = một lộ trình học (ví dụ "Minna no Nihongo N5") gồm nhiều Lesson
// có thứ tự cố định. User enroll vào course → có UserCourseProgress.
// Mỗi Lesson có theory (markdown), tham chiếu tới 0–N Deck để ôn tập SM-2,
// và một LessonTest (1:1) trỏ tới Deck dùng làm quiz để pass bài.

enum SkillType {
  VOCABULARY // Từ vựng (Goi)
  KANJI      // Hán tự (Moji)
  GRAMMAR    // Ngữ pháp (Bunpou)
  READING    // Đọc hiểu (Dokkai)
  LISTENING  // Nghe hiểu (Choukai)
}


model Course {
  id          String   @id @default(uuid())
  slug        String   @unique // "minna-n5", "minna-n4", ...
  title       String
  description String?
  jlptLevel   Int      // 5, 4, 3, 2, 1
  textbookRef String?  // "Minna no Nihongo I", "Genki I", ...
  isDefault   Boolean  @default(false) // Course mặc định cho level
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lessons   Lesson[]
  enrolls   UserCourseProgress[]

  @@index([jlptLevel, isDefault])
}

model Lesson {
  id            String   @id @default(uuid())
  courseId      String
  order         Int      // Thứ tự trong course (1, 2, 3, ...)
  title         String   // "Bài 1 - Watashi wa ..."
  skills        SkillType[] // 1 bài có thể cover 1 hoặc nhiều kỹ năng
  summary       String?  // Tóm tắt ngắn 1 dòng cho UI list
  theoryMd      String   @db.Text // Nội dung lí thuyết dạng markdown
  estimatedMin  Int      @default(30)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  course   Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  decks    LessonDeck[]
  test     LessonTest?
  progress UserLessonProgress[]
  customItems CustomRoadmapItem[]

  @@unique([courseId, order])
  @@index([courseId])
}

enum LessonDeckRole {
  VOCAB   // Từ vựng để ôn flashcard SM-2
  KANJI   // Hán tự
  GRAMMAR // Ngữ pháp
}

// Bảng nối Lesson ↔ Deck cho các deck "học/ôn" trong bài
// (không phải deck dùng làm bài test cuối bài — cái đó là LessonTest)
model LessonDeck {
  lessonId String
  deckId   String
  role     LessonDeckRole @default(VOCAB)
  order    Int            @default(0)

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  deck   Deck   @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@id([lessonId, deckId])
  @@index([deckId])
}

// Test cuối bài — tham chiếu một Deck đã có (dùng làm pool câu hỏi quiz)
// 1 lesson chỉ có tối đa 1 test (1:1)
model LessonTest {
  id         String @id @default(uuid())
  lessonId   String @unique
  deckId     String
  passScore  Int    @default(70) // % để pass (0-100)
  questionCount Int @default(10)  // Số câu trong 1 lượt test

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  deck   Deck   @relation(fields: [deckId], references: [id])

  @@index([deckId])
}

// Tiến độ user trong một course (1 user enroll 1 course = 1 row)
model UserCourseProgress {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  startedAt  DateTime @default(now())
  targetDate DateTime? // Ngày mục tiêu hoàn thành (deadline) — null = không đặt
  goal       String?   // Free-text mục tiêu (ví dụ "Thi N5 12/2026")
  isActive   Boolean  @default(true) // user có thể tạm dừng course
  updatedAt  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

enum LessonStatus {
  NOT_STARTED
  IN_PROGRESS
  PASSED
}

model UserLessonProgress {
  id          String       @id @default(uuid())
  userId      String
  lessonId    String
  status      LessonStatus @default(NOT_STARTED)
  score       Int?         // điểm test gần nhất (0-100)
  attemptCount Int         @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime     @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, status])
}

// ============================================================================
// AI PERSONALIZED ROADMAP (CÁCH NÂNG CAO)
// ============================================================================

model CustomRoadmap {
  id          String   @id @default(uuid())
  userId      String
  title       String   // vd: "Lộ trình 3 tháng chinh phục IT N4"
  description String?
  goal        String?
  targetDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phases      CustomRoadmapPhase[]

  @@index([userId])
}

model CustomRoadmapPhase {
  id          String   @id @default(uuid())
  roadmapId   String
  order       Int      // Thứ tự (vd: 1 = Tuần 1, 2 = Tuần 2)
  title       String   // vd: "Tuần 1: Nền tảng từ vựng IT"
  description String?
  
  roadmap     CustomRoadmap @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  items       CustomRoadmapItem[]

  @@index([roadmapId])
}

model CustomRoadmapItem {
  id          String   @id @default(uuid())
  phaseId     String
  order       Int
  lessonId    String?  // Trỏ tới một Lesson có sẵn trong hệ thống (Optional)
  customTitle String?  // Tên task tự do (nếu AI tạo ra một bài tập ngoài)
  customDesc  String?  // Mô tả task tự do
  isCompleted Boolean  @default(false)
  completedAt DateTime?

  phase       CustomRoadmapPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  lesson      Lesson?            @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([phaseId])
}

model GrammarPractice {
  id          String   @id @default(uuid())
  userId      String
  cardId      String
  userAnswer  String   @db.Text
  isCorrect   Boolean
  score       Int
  feedback    String   @db.Text
  suggestion  String   @db.Text
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, cardId])
}

model UserSavedExample {
  id         String   @id @default(uuid())
  userId     String
  cardId     String
  japanese   String   @db.Text
  romaji     String?  @db.Text
  vietnamese String   @db.Text
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId, japanese])
  @@index([userId, cardId])
}

// ============================================================================
// FEEDBACK
// ============================================================================

enum FeedbackType {
  BUG
  FEATURE
  CONTENT
  UI_UX
  OTHER
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

model Feedback {
  id          String         @id @default(uuid())
  userId      String
  type        FeedbackType
  message     String         @db.Text
  imageUrls   String[]
  status      FeedbackStatus @default(PENDING)
  adminNote   String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments    FeedbackComment[]

  @@index([userId])
  @@index([status])
  @@index([type])
}

model FeedbackComment {
  id         String   @id @default(uuid())
  feedbackId String
  userId     String
  message    String   @db.Text
  createdAt  DateTime @default(now())

  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@index([userId])
}
