# ─────────────────────────────────────────────────────────────────────────────
# Minhongo — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values before running docker compose
#   cp .env.example .env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=minhongo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example for VPS: CORS_ORIGIN=https://yourdomain.com
# ⚠ Nếu đổi FRONTEND_PORT (VD: 8080), PHẢI cập nhật CORS_ORIGIN cho khớp!
# VD: CORS_ORIGIN=http://localhost:8080
CORS_ORIGIN=http://localhost

# Port to expose backend on host (default 3000)
BACKEND_PORT=3000

# ── SMTP (email gửi link reset password) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Minhongo <your_gmail@gmail.com>

# URL frontend — dùng trong link email reset password
# Example for VPS: FRONTEND_URL=https://yourdomain.com
FRONTEND_URL=http://localhost

# ── Frontend (baked in at build time) ────────────────────────────────────────
# Must be the publicly reachable URL of the backend
# Example for VPS: VITE_API_URL=https://yourdomain.com:3000
VITE_API_URL=http://localhost:3000

# Port frontend expose ra ngoài (default: 80)
# Windows local: dùng 8080 vì port 80 có thể bị chiếm
# VPS Linux: dùng 80
FRONTEND_PORT=80

# ── AWS S3 (lưu trữ ảnh avatar, v.v.) ───────────────────────────────────────
# Tạo IAM User với quyền s3:PutObject, s3:DeleteObject trên bucket của bạn
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=your-bucket-name
# (tuỳ chọn) Custom domain nếu dùng CloudFront CDN
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com

# ── Google Gemini AI ─────────────────────────────────────────────────────────
# Yêu cầu để chạy AI Tutor và các chức năng sinh bài tập tự động bằng AI
GEMINI_API_KEY=your_gemini_api_key

