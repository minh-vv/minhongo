# Copy this file to .env and fill in values before running docker compose

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=minhongo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_strong_password

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example for VPS: CORS_ORIGIN=http://123.45.67.89
CORS_ORIGIN=http://localhost

# ── SMTP (email gửi link reset password) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=Minhongo <your_gmail@gmail.com>

# URL frontend — dùng trong link email reset password
FRONTEND_URL=http://localhost

# ── Frontend (baked in at build time) ────────────────────────────────────────
# Must be the publicly reachable URL of the backend
# Example for VPS: VITE_API_URL=http://123.45.67.89:3002
VITE_API_URL=http://localhost:3002
